# ─── Base de datos ───────────────────────────────────────────────────────────
POSTGRES_USER=equilibria_user
POSTGRES_PASSWORD=cambia_esto_por_password_seguro
POSTGRES_DB=equilibria_db

# Solo necesario para conectar desde fuera de Docker (Prisma Studio, DBeaver, etc.)
DATABASE_URL=postgresql://equilibria_user:cambia_esto@localhost:5432/equilibria_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=production
